{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": ["jasmine", "node"],
    "target": "ES2020",
    "lib": ["ES2020", "dom"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/**/**/*.spec.ts",
    "src/**/**/**/*.spec.ts"
  ]
}
